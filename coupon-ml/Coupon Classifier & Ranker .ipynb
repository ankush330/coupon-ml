    "# Start fresh from original data\n",
    "data_clean = df[['text', 'label']].copy()\n",
    "\n",
    
    "features = data_clean['text'].apply(extract_features)\n",
    "features_df = pd.DataFrame(features.tolist())\n",
    "\n",
    "df_final = pd.concat([data_clean, features_df], axis=1)\n",
    "\n",
    "print(\"Clean dataset ✅\")\n",
    "print(f\"Shape: {df_final.shape}\")\n",
    "print(f\"Columns: {list(df_final.columns)}\")\n",
    "df_final.head(5)"
   ]
