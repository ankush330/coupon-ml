    ")\n",
    "\n",
    "reg = XGBRegressor(n_estimators=100, max_depth=4, random_state=42)\n",
    "reg.fit(X_train_r, y_train_r)\n",
    "\n",
    "y_pred_r = reg.predict(X_test_r)\n",
    "\n",
    "mae = mean_absolute_error(y_test_r, y_pred_r)\n",
