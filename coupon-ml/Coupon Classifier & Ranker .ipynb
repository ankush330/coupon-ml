    "def estimate_real_value(row):\n",
    "    if row['label'] == 'FLAT_CASHBACK':\n",
    "        return row['max_amount'] * 1.0       
    "    elif row['label'] == 'UPTO_CASHBACK':\n",
    "        return row['max_amount'] * 0.30        
    "    elif row['label'] == 'FLAT_PERCENT':\n",
    "        order = max(row['min_order'], 500)\n",
    "        return (row['max_percent'] / 100) * order\n",
    "    elif row['label'] == 'UPTO_PERCENT':\n",
    "        order = max(row['min_order'], 500)\n",
    "        return (row['max_percent'] / 100) * order * 0.30\n",
    "    return 0\n",
    "\n",
    "df_final['expected_value'] = df_final.apply(estimate_real_value, axis=1)\n",
    "\n",
    "print(\"Expected value sample:\")\n",
    "df_final[['text', 'label', 'max_amount', 'expected_value']].head(10)"
   ]
