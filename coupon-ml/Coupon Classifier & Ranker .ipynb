    "def rank_coupons(coupon_list):\n",
    "    results = []\n",
    "    for text in coupon_list:\n",
    "        cleaned = text.lower()\n",
    "        feats   = extract_features(cleaned)\n",
    "        feat_vec = [[\n",
    "            feats['is_upto'], feats['is_flat'], feats['is_percent'],\n",
    "            feats['max_amount'], feats['max_percent'],\n",
    "            feats['min_order'], feats['value_ratio']\n",
    "        ]]\n",
    "        coupon_type = le.inverse_transform(clf.predict(feat_vec))[0]\n",
    "        exp_value   = reg.predict(feat_vec)[0]\n",
    "\n",
    "        results.append({\n",
    "            'Coupon':       text,\n",
    "            'Type':         coupon_type,\n",
    "            'Expected Rs.': round(exp_value, 2)\n",
    "        })\n",
    "\n",
    "    ranked = pd.DataFrame(results).sort_values('Expected Rs.', ascending=False)\n",
    "    ranked.index = range(1, len(ranked) + 1)\n",
    "    return ranked\n",
    "\n",
    
    "my_coupons = [\n",
    "    'Get upto Rs.200 cashback on orders above Rs.999',\n",
    "    'Flat Rs.150 cashback on minimum order Rs.500',\n",
    "    'Upto 30% off on orders above Rs.1000',\n",
    "    'Flat Rs.100 cashback no minimum order',\n",
    "    'Upto Rs.500 cashback on first order above Rs.2000',\n",
    "    'Guaranteed Rs.75 cashback on recharge above Rs.199',\n",
    "]\n",
    "\n",
    "rank_coupons(my_coupons) "
   ]
  },
