    "def get_label(text):\n",
    "    t = text.lower()\n",
    "    is_upto    = bool(re.search(r'\\bupto\\b|up to|maximum|max\\b', t))\n",
    "    is_percent = bool(re.search(r'\\d+\\s*%', t))\n",
    "\n",
    "    if is_upto and is_percent:\n",
    "        return 'UPTO_PERCENT'\n",
    "    elif is_upto:\n",
    "        return 'UPTO_CASHBACK'\n",
    "    elif is_percent:\n",
    "        return 'FLAT_PERCENT'\n",
    "    else:\n",
    "        return 'FLAT_CASHBACK'\n",
    "\n",
    "df['label'] = df['text'].apply(get_label)\n",
    "\n",
    "print(\"Label distribution:\")\n",
    "print(df['label'].value_counts())"
   ]
